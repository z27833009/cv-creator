<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CV - {{ personal.name }}</title>
<style>
  @page {
    size: A4;
    margin: 0;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    font-size: 10pt;
    line-height: 1.55;
    color: #1a1a1a;
    background: #fff;
    -webkit-font-smoothing: antialiased;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* Fixed stripe — Chromium repeats position:fixed elements on every
     printed page, so the dark sidebar background extends to full height
     on every page regardless of content length. */
  body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 68mm;
    height: 100vh;
    background: #1b2a3d;
    z-index: -1;
  }

  .page {
    width: 210mm;
    min-height: 297mm;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 68mm 1fr;
  }

  @media screen {
    body { background: #f0ebe3; }
    .page {
      margin: 20px auto;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }
  }

  /* ── Left Sidebar ── */
  .sidebar {
    background: transparent;
    color: #d0d8e0;
    padding: 12mm 6mm 12mm 6mm;
    display: flex;
    flex-direction: column;
    gap: 6mm;
  }

  .photo-container {
    display: flex;
    justify-content: center;
    margin-bottom: 2mm;
  }
  .photo-container img {
    width: 38mm;
    height: 38mm;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2.5px solid #56c8c4;
  }

  .sidebar h2 {
    font-size: 9pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    color: #56c8c4;
    margin-bottom: 3mm;
    padding-bottom: 2mm;
    border-bottom: 1px solid rgba(86,200,196,0.3);
  }

  .sidebar .block { margin-bottom: 1mm; }

  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 1.2mm 0;
    font-size: 9pt;
  }
  .info-label { color: #8a9bb0; }
  .info-value { color: #d0d8e0; text-align: right; }

  .skill-category { margin-bottom: 3mm; }
  .skill-category-title {
    font-size: 8.5pt;
    font-weight: 600;
    color: #56c8c4;
    margin-bottom: 1mm;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 2px 4px;
  }
  .skill-tag {
    font-size: 8pt;
    color: #c0cad4;
    background: rgba(255,255,255,0.06);
    padding: 2px 6px;
    border-radius: 3px;
    line-height: 1.6;
  }

  .lang-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5mm 0;
    font-size: 9pt;
  }
  .lang-name { color: #d0d8e0; }
  .lang-level { color: #8a9bb0; font-size: 8pt; }

  .sidebar-extra {
    font-size: 8.5pt;
    color: #8a9bb0;
    line-height: 1.55;
    margin-bottom: 2mm;
  }
  .sidebar-extra strong { color: #d0d8e0; }

  /* ── Main Content ── */
  .main {
    padding: 12mm 10mm 12mm 10mm;
    display: flex;
    flex-direction: column;
    gap: 5.5mm;
  }

  .header { margin-bottom: 1mm; }
  .header h1 {
    font-size: 24pt;
    font-weight: 700;
    color: #1b2a3d;
    letter-spacing: 0.5px;
  }
  .header .subtitle {
    font-size: 11pt;
    color: #56c8c4;
    font-weight: 500;
    margin-top: 1mm;
  }
  .header .summary {
    margin-top: 3mm;
    font-size: 9.5pt;
    color: #4a5568;
    line-height: 1.6;
  }

  .section-title {
    font-size: 10pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #1b2a3d;
    padding-bottom: 2mm;
    border-bottom: 2px solid #56c8c4;
    margin-bottom: 4mm;
  }

  .entry {
    margin-bottom: 4.5mm;
    page-break-inside: avoid;
  }
  .entry:last-child { margin-bottom: 0; }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5mm;
  }
  .entry-title {
    font-size: 10.5pt;
    font-weight: 700;
    color: #1b2a3d;
  }
  .entry-date {
    font-size: 8pt;
    color: #718096;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 3mm;
  }

  .entry-sub {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1mm;
  }
  .entry-role {
    font-size: 9pt;
    font-style: italic;
    color: #56c8c4;
  }
  .entry-location {
    font-size: 8pt;
    color: #718096;
    flex-shrink: 0;
  }

  .entry ul { padding-left: 4mm; }
  .entry li {
    font-size: 9.5pt;
    color: #2d3748;
    margin-bottom: 1.2mm;
    line-height: 1.55;
  }

  .edu-entry { margin-bottom: 3.5mm; }
  .edu-detail {
    font-size: 9pt;
    color: #4a5568;
    margin-top: 0.5mm;
    padding-left: 1mm;
    line-height: 1.55;
    white-space: pre-line;
  }
</style>
</head>
<body>
<div class="page">

  <!-- ════════ LEFT SIDEBAR ════════ -->
  <div class="sidebar">

    {% if personal.photo_data_uri %}
    <div class="photo-container">
      <img src="{{ personal.photo_data_uri }}" alt="{{ personal.name }}">
    </div>
    {% endif %}

    <div class="block">
      <h2>Personal</h2>
      {% if personal.birth %}<div class="info-row"><span class="info-label">Birth</span><span class="info-value">{{ personal.birth }}</span></div>{% endif %}
      {% if personal.nationality %}<div class="info-row"><span class="info-label">Nationality</span><span class="info-value">{{ personal.nationality }}</span></div>{% endif %}
      {% if personal.address %}<div class="info-row"><span class="info-label">Address</span><span class="info-value">{{ personal.address }}</span></div>{% endif %}
      {% if personal.available %}<div class="info-row"><span class="info-label">Available</span><span class="info-value">{{ personal.available }}</span></div>{% endif %}
      {% if personal.email %}<div class="info-row"><span class="info-label">Email</span><span class="info-value">{{ personal.email }}</span></div>{% endif %}
      {% if personal.phone %}<div class="info-row"><span class="info-label">Phone</span><span class="info-value">{{ personal.phone }}</span></div>{% endif %}
      {% if personal.linkedin %}<div class="info-row"><span class="info-label">LinkedIn</span><span class="info-value">{{ personal.linkedin }}</span></div>{% endif %}
      {% if personal.github %}<div class="info-row"><span class="info-label">GitHub</span><span class="info-value">{{ personal.github }}</span></div>{% endif %}
      {% if personal.website %}<div class="info-row"><span class="info-label">Website</span><span class="info-value">{{ personal.website }}</span></div>{% endif %}
    </div>

    {% if skills %}
    <div class="block">
      <h2>IT Skills</h2>
      {% for cat in skills %}
      <div class="skill-category">
        <div class="skill-category-title">{{ cat.category }}</div>
        <div class="skill-tags">
          {% for tag in cat.tags %}<span class="skill-tag">{{ tag }}</span>{% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if languages %}
    <div class="block">
      <h2>Languages</h2>
      {% for lang in languages %}
      <div class="lang-row"><span class="lang-name">{{ lang.name }}</span><span class="lang-level">{{ lang.level }}</span></div>
      {% endfor %}
    </div>
    {% endif %}

    {% if extras %}
    <div class="block">
      <h2>Scholarships</h2>
      {% for item in extras %}
      <div class="sidebar-extra">
        <strong>{{ item.title }}</strong>{% if item.subtitle %}<br>{{ item.subtitle }}{% endif %}{% if item.meta %}<br>{{ item.meta }}{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>

  <!-- ════════ MAIN CONTENT ════════ -->
  <div class="main">

    <div class="header">
      <h1>{{ personal.name }}</h1>
      {% if personal.title %}<div class="subtitle">{{ personal.title }}</div>{% endif %}
      {% if summary %}<div class="summary">{{ summary }}</div>{% endif %}
    </div>

    {% if work %}
    <div class="section">
      <div class="section-title">Work Experience</div>
      {% for job in work %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ job.title }}</span>
          <span class="entry-date">{{ job.date }}</span>
        </div>
        {% if job.role or job.location %}
        <div class="entry-sub">
          <span class="entry-role">{{ job.role or '' }}</span>
          <span class="entry-location">{{ job.location or '' }}</span>
        </div>
        {% endif %}
        {% if job.bullets %}
        <ul>
          {% for b in job.bullets %}<li>{{ b|flat }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if projects %}
    <div class="section">
      <div class="section-title">Project Experience</div>
      {% for p in projects %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ p.title }}</span>
          <span class="entry-date">{{ p.date }}</span>
        </div>
        {% if p.role or p.location %}
        <div class="entry-sub">
          <span class="entry-role">{{ p.role or '' }}</span>
          <span class="entry-location">{{ p.location or '' }}</span>
        </div>
        {% endif %}
        {% if p.bullets %}
        <ul>
          {% for b in p.bullets %}<li>{{ b|flat }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if education %}
    <div class="section">
      <div class="section-title">Education</div>
      {% for e in education %}
      <div class="edu-entry">
        <div class="entry-header">
          <span class="entry-title">{{ e.title }}</span>
          <span class="entry-date">{{ e.date }}</span>
        </div>
        {% if e.degree or e.details %}
        <div class="edu-detail">{% if e.degree %}<strong>{{ e.degree }}</strong>
{% endif %}{{ e.details|flat }}</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>
</div>
</body>
</html>
